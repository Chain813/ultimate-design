data/rag_knowledge.json
config_daemon.json
assets/default_cover.jpg

# 内部文档与代理运行痕迹
docs/
.agents/

# IDE & 系统文件
.vscode/
.idea/
.DS_Store
Thumbs.db

# 排除所有 PDF (防止 GitHub 大文件限制)
*.pdf
