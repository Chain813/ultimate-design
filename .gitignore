# Python 缓存
__pycache__/
*.py[cod]
*$py.class
dist/
build/
*.egg-info/

# Streamlit 缓存与配置
.streamlit/*
!.streamlit/config.toml
.runtime-packages/

# 本地环境变量
.env

# 离线大数据与媒体文件 (排除 GB 级大文件)
data/streetview/
data/raw_images/
data/template_assets/
archive/
data/shp/road_network.json
data/shp/rail_network.json
data/shp/Building_Footprints.geojson

# 日志与临时元数据
*.log
*.err
*.err.log
data/rag_knowledge.json
config_daemon.json
assets/default_cover.jpg

# 内部文档与代理运行痕迹
docs/
.agents/

# IDE & 系统文件
.vscode/
.idea/
.DS_Store
Thumbs.db

# 排除所有 PDF (防止 GitHub 大文件限制)
*.pdf

# Node.js 依赖
node_modules/

# 视频生成输出（大文件）
tools/video_generator/output/
tools/video_generator/composer/node_modules/

# 临时工作目录
*.tmp
*.bak
